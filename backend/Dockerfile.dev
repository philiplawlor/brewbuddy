# Backend - Development Dockerfile
# Hot reload enabled for development

FROM node:20-alpine
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install all dependencies (including dev)
RUN npm ci

# Copy source code
COPY . .

# Expose API port
EXPOSE 3001

# Set environment
ENV NODE_ENV=development

# Start with nodemon for hot reload
CMD ["npm", "run", "dev"]
