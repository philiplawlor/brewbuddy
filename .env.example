# MongoDB
MONGODB_URI=mongodb://mongodb:27017/brewbuddy
MONGODB_INITDB_ROOT_USERNAME=admin
MONGODB_INITDB_ROOT_PASSWORD=REPLACE_WITH_A_STRONG_PASSWORD

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=REPLACE_WITH_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3001/api

# Device Integration (optional)
TILT_ENABLED=false
ISPINDEL_ENABLED=false
