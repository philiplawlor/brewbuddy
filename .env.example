# MongoDB
MONGODB_URI=mongodb://mongodb:27017/brewbuddy
MONGODB_INITDB_ROOT_USERNAME=admin
MONGODB_INITDB_ROOT_PASSWORD=changeme_in_production

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3001/api

# Device Integration (optional)
TILT_ENABLED=false
ISPINDEL_ENABLED=false
